# Claude Code local settings (settings.json is committed for team hooks)
.claude/settings.local.json
.claude/projects/
.claude/worktrees/

# Worktrees
.worktrees/

# Dependencies
node_modules

# Build outputs
dist/
build/

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Test artifacts (local session data)
/diagrams/
/documents/
/metadata.json
# Collab data directory
/.collab/sessions/
/.collab/**/*.tmp
# Local runtime artifacts (agent/todo sqlite, agent sessions)
/.collab/*.db
/.collab/*.db-shm
/.collab/*.db-wal
/.collab/todos.json
/.collab/agent-sessions/
# Coordinator attempt records (runtime provenance; not source)
/.collab/attempts/
# Generated leaf-executor artifacts (blueprints + per-node transcripts; runtime, not source)
/.collab/leaf-blueprints/
/.collab/leaf-transcripts/
# Generated project-digest artifacts (digest + metadata; runtime, not source)
/.collab/project-digest.md
/.collab/project-digest.meta.json
# Desktop app local runtime collab data
/desktop/.collab/
# Scheduled-tasks runtime lock
/.claude/scheduled_tasks.lock
/scratch/
/extensions/vscode/*.vsix
.worktrees/

# redundant npm lockfile — root installs with bun (see CI build-windows)
/package-lock.json

# bun --compile intermediate artifacts
*.bun-build
.*.bun-build

# Test-run artifacts (vitest/bun output redirects, coverage) — never source.
# stage-untracked.ts enumerates with `git ls-files --others --exclude-standard`, which
# honors these rules, so ignoring here is what stops junk being intent-to-added.
/*.log
/coverage/
/ui/coverage/
/ui/test-output*

# SQLite ephemeral WAL/SHM sidecars — never belong in git (bug 36393ef2)
*.db-shm
*.db-wal
**/.collab/*.db-shm
**/.collab/*.db-wal

# Stray mis-rooted .collab artifacts (a process ran with cwd=proj/)
/proj/
