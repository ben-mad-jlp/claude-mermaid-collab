{
  "version": 1,
  "gateCommand": "npx tsc --noEmit",
  "changeSetTestCommand": "bunx vitest --run {files}",
  "changeSetTestCwd": "ui",
  "gate": {
    "typecheck": "npx tsc --noEmit -p tsconfig.json",
    "tests": [
      { "match": "^src/", "command": "bun test {file}" },
      { "match": "^scripts/", "command": "bun test {file}" },
      { "match": "^ui/", "command": "bunx vitest --run {files}", "cwd": "ui" }
    ],
    "typechecks": [
      { "match": "^ui/", "command": "npx tsc --noEmit -p tsconfig.json", "cwd": "ui" }
    ],
    "suites": [
      { "match": "^ui/", "command": "bunx vitest --run", "cwd": "ui" }
    ],
    "floors": [
      { "match": "^(src|scripts)/", "command": "bun run scripts/test-backend.ts --baseline=scripts/backend-test-baseline.json" }
    ]
  }
}
