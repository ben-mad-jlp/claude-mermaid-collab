{
  "name": "mermaid-collab-desktop",
  "private": true,
  "version": "6.18.0",
  "description": "mermaid-collab native desktop app (Electron)",
  "homepage": "https://github.com/ben-mad-jlp/claude-mermaid-collab",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:sidecar": "bun run scripts/build-sidecar.ts",
    "build:ui": "cd ../ui && bunx vite build",
    "dist": "npm run build:ui && npm run build && npm run build:sidecar && electron-builder",
    "dist:dir": "npm run build:ui && npm run build && npm run build:sidecar && electron-builder --dir",
    "spike": "electron spikes/main.js",
    "spike:full": "electron spikes/extended.js"
  },
  "dependencies": {
    "electron-agent-bridge": "github:ben-mad-jlp/electron-agent-bridge#9b659619c9c2149582b2ea3655211a6d7cab92db",
    "electron-updater": "^6.3.9",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "electron": "^37.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.mermaid-collab.desktop",
    "productName": "Mermaid Collab",
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../ui/dist",
        "to": "ui/dist"
      },
      {
        "from": "../public",
        "to": "public"
      },
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "mc-server",
          "mc-server.exe",
          "ffmpeg",
          "ffmpeg.exe",
          "ffprobe",
          "ffprobe.exe"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "JLP Engineering <bmaderazo@jlpengineering.com>",
      "publish": {
        "provider": "generic",
        "url": "${env.MC_UPDATE_FEED_URL}",
        "channel": "latest"
      }
    },
    "appImage": {
      "artifactName": "mermaid-collab-${version}-${arch}.AppImage"
    },
    "deb": {
      "packageCategory": "devel",
      "priority": "optional",
      "depends": [
        "mermaid-collab-server",
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libxcb-dri3-0"
      ]
    },
    "publish": null
  },
  "trustedDependencies": [
    "electron-agent-bridge"
  ]
}
