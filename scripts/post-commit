#!/bin/bash
# Git post-commit hook for pseudo file tracking.
#
# This file is committed to the repo at scripts/post-commit.
# Install it with: /pseudocode install
# Or manually: cp scripts/post-commit .git/hooks/post-commit && chmod +x .git/hooks/post-commit

SCRIPT="$(git rev-parse --show-toplevel)/scripts/pseudo-track-commit.sh"

if [ -f "$SCRIPT" ]; then
  bash "$SCRIPT"
fi
