{"code":"using System;\nusing System.Collections.Generic;\nusing System.Linq;\n\nnamespace Example\n{\n    public class HelloWorld\n    {\n        private readonly string _message;\n        private readonly List<string> _recipients;\n\n        public HelloWorld(string message, List<string> recipients)\n        {\n            _message = message;\n            _recipients = recipients;\n        }\n\n        public void GreetAll()\n        {\n            foreach (var recipient in _recipients.OrderBy(r => r))\n            {\n                var greeting = string.Format(\"{0}, {1}!\", _message, recipient);\n                Console.WriteLine(greeting);\n            }\n        }\n\n        public static void Main(string[] args)\n        {\n            var recipients = new List<string> { \"World\", \"Alice\", \"Bob\" };\n            var hw = new HelloWorld(\"Hello\", recipients);\n            hw.GreetAll();\n        }\n    }\n}","language":"c#","filePath":"HelloWorld.cs","originalCode":"using System;\nusing System.Collections.Generic;\nusing System.Linq;\n\nnamespace Example\n{\n    public class HelloWorld\n    {\n        private readonly string _message;\n        private readonly List<string> _recipients;\n\n        public HelloWorld(string message, List<string> recipients)\n        {\n            _message = message;\n            _recipients = recipients;\n        }\n\n        public void GreetAll()\n        {\n            foreach (var recipient in _recipients.OrderBy(r => r))\n            {\n                var greeting = string.Format(\"{0}, {1}!\", _message, recipient);\n                Console.WriteLine(greeting);\n            }\n        }\n\n        public static void Main(string[] args)\n        {\n            var recipients = new List<string> { \"World\", \"Alice\", \"Bob\" };\n            var hw = new HelloWorld(\"Hello\", recipients);\n            hw.GreetAll();\n        }\n    }\n}"}