{"language":"python","code":"def fibonacci(n: int) -> list[int]:\n    \"\"\"Generate the first n Fibonacci numbers.\"\"\"\n    if n <= 0:\n        return []\n    if n == 1:\n        return [0]\n    fib = [0, 1]\n    for i in range(2, n):\n        fib.append(fib[-1] + fib[-2])\n    return fib\n\n# Updated via MCP!\nresult = fibonacci(15)\nprint(f\"First 15 Fibonacci numbers: {result}\")\n# Edited from Chrome browser!\n","filePath":"scripts/fibonacci.py","highlightLines":[2,12,13,14]}