{
  "code": "/**\n * Migrate pseudo DB file paths from .pseudo extensions to actual source file extensions.\n * Run: cd /Users/benmaderazo/Code/claude-mermaid-collab && bun scratch/migrate-pseudo-paths.ts\n */\nimport { getPseudoDb } from '../src/services/pseudo-db';\nimport { existsSync } from 'fs';\nimport { join } from 'path';\n\nconst PROJECT = '/Users/benmaderazo/Code/claude-mermaid-collab';\nconst db = getPseudoDb(PROJECT);\n\nconst files = db.listFiles();\nconsole.log(`Found ${files.length} files in DB\\n`);\n\nconst EXTENSIONS = ['.ts', '.tsx', '.js', '.jsx', '.sh', '.json', '.css', '.html', '.md'];\n\nlet updated = 0;\nlet notFound = 0;\nlet alreadyCorrect = 0;\n\nfor (const file of files) {\n  const oldPath = file.filePath;\n\n  // Already has a real extension (not .pseudo)\n  if (!oldPath.endsWith('.pseudo')) {\n    alreadyCorrect++;\n    continue;\n  }\n\n  // Strip .pseudo extension\n  const basePath = oldPath.replace(/\\.pseudo$/, '');\n\n  // Try each extension\n  let newPath: string | null = null;\n  for (const ext of EXTENSIONS) {\n    const candidate = basePath + ext;\n    if (existsSync(join(PROJECT, candidate))) {\n      newPath = candidate;\n      break;\n    }\n  }\n\n  // Also try without any extension (for files like Dockerfile, Makefile)\n  if (!newPath && existsSync(join(PROJECT, basePath))) {\n    newPath = basePath;\n  }\n\n  if (newPath) {\n    // Update the DB entry\n    const newStem = newPath.split('/').pop()?.replace(/\\.[^.]+$/, '') || newPath;\n\n    // Direct SQL update for the file path and stem\n    (db as any).db.prepare('UPDATE files SET file_path = ?, file_stem = ? WHERE file_path = ?')\n      .run(newPath, newStem, oldPath);\n\n    console.log(`✅ ${oldPath} → ${newPath}`);\n    updated++;\n  } else {\n    console.log(`❌ ${oldPath} — no source file found`);\n    notFound++;\n  }\n}\n\nconsole.log(`\\nResults: ${updated} updated, ${notFound} not found, ${alreadyCorrect} already correct`);\n\ndb.close();\n",
