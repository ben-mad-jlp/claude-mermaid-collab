flowchart TD
    subgraph BEFORE["BEFORE (current)"]
        direction TB
        B1["binary checkbox toggle\n(completed true/false)"]:::before
        B2[".text field\n(todo.text, draftText)"]:::before
        B3["numeric id display\n(#todo.id — raw integer)"]:::before
        B4["no filter row\n(only show-completed checkbox)"]:::before
        B5["no assignee/priority/due badges"]:::before
        B6["api.patchSessionTodo id: number\nremoveSessionTodo id: number\nreorderSessionTodos orderedIds: number[]"]:::before
        B7["store removeSessionTodoLocal id: number"]:::before
        B8["addSessionTodo(project, session, text)"]:::before
    end

    subgraph AFTER["AFTER (target)"]
        direction TB
        A1["status cycle control\n(backlog→todo→in_progress→blocked→done)\ncompleted derived from status===done"]:::after
        A2[".title field\n(todo.title; .text kept as deprecated alias)"]:::after
        A3["truncated id display\n(todo.id.slice(0,6) or dropped)"]:::after
        A4["filter row\n(status multi-select + assigned-to-me toggle)"]:::after
        A5["assignee badge (assigneeSession)\npriority badge (priority)\ndue badge (dueDate) — shown when present"]:::after
        A6["api.patchSessionTodo id: string\nremoveSessionTodo id: string\nreorderSessionTodos orderedIds: string[]"]:::after
        A7["store removeSessionTodoLocal id: string"]:::after
        A8["addSessionTodo(project, session, title, link?, {status?, assigneeSession?, priority?, dueDate?})"]:::after
    end

    classDef before fill:#ffdddd,stroke:#ffaaaa
    classDef after fill:#ddffdd,stroke:#aaffaa
