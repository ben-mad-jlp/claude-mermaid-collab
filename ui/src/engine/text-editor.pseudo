// In-place text editor state machine
// Manages cursor position, text selection, character insertion/deletion, and caret/selection rectangle computation for an active text-editing session on a SceneNode using a CanvasKit Paragraph for glyph metrics.
// synced: 2026-03-26T00:00:00Z

CLASS TextEditor
  State: ck (CanvasKit), renderer (SkiaRenderer | null), _state (TextEditorState | null), caretVisible (bool)

  FUNCTION start(node: SceneNode) -> void [2026-03-26]
    CALLS: buildParagraph (renderer)
    Initialises a fresh TextEditorState for the node, placing the cursor at the end, and builds the initial CanvasKit Paragraph.

  ---

  FUNCTION stop() -> { nodeId, text } | null [2026-03-26]
    Frees the Paragraph WASM object, clears internal state, and returns the final node ID and text. Returns null if not active.

  ---

  FUNCTION rebuildParagraph(node: SceneNode) -> void [2026-03-26]
    CALLS: buildParagraph (renderer)
    Deletes any existing Paragraph object and rebuilds it from the current node, needed after every text mutation.

  ---

  FUNCTION hasSelection() -> boolean [2026-03-26]
    Returns true when selectionAnchor is set and differs from cursor.

  ---

  FUNCTION getSelectionRange() -> [lo, hi] | null [2026-03-26]
    Returns the ordered [start, end] of the current selection, or null if none.

  ---

  FUNCTION getSelectedText() -> string [2026-03-26]
    CALLS: getSelectionRange (text-editor)
    Slices and returns the currently selected text.

  ---

  FUNCTION selectAll() -> void [2026-03-26]
    Sets selectionAnchor to 0 and cursor to text.length.

  ---

  FUNCTION selectWord(pos) -> void [2026-03-26]
    Expands the selection outward from pos to the nearest word boundaries on both sides.

  ---

  FUNCTION setCursorAt(x, y, extend?) -> void [2026-03-26]
    Uses the Paragraph's getGlyphPositionAtCoordinate to map a canvas point to a character index and sets the cursor there, optionally extending the selection.

  ---

  FUNCTION selectLine(pos) -> void [2026-03-26]
    Uses Paragraph line metrics to select the entire line containing the given character position.

  ---

  FUNCTION selectWordAt(x, y) -> void [2026-03-26]
    CALLS: selectWord (text-editor)
    Resolves the glyph position at canvas coordinates then delegates to selectWord.

  ---

  FUNCTION selectLineAt(x, y) -> void [2026-03-26]
    CALLS: selectLine (text-editor)
    Resolves the glyph position at canvas coordinates then delegates to selectLine.

  ---

  FUNCTION insert(text, node) -> void [2026-03-26]
    CALLS: rebuildParagraph (text-editor)
    Replaces the selection (if any) or inserts at cursor, advances cursor, clears anchor, and rebuilds the paragraph.

  ---

  FUNCTION backspace(node) -> void [2026-03-26]
    CALLS: rebuildParagraph (text-editor)
    Deletes the selection or the character before the cursor, updates cursor, and rebuilds the paragraph.

  ---

  FUNCTION delete(node) -> void [2026-03-26]
    CALLS: rebuildParagraph (text-editor)
    Deletes the selection or the character after the cursor, and rebuilds the paragraph.

  ---

  FUNCTION moveLeft(extend?) -> void [2026-03-26]
    Collapses selection to its left end (if extend is false and there is a selection), or moves cursor one character left.

  ---

  FUNCTION moveRight(extend?) -> void [2026-03-26]
    Collapses selection to its right end (if extend is false and there is a selection), or moves cursor one character right.

  ---

  FUNCTION moveUp(extend?) -> void [2026-03-26]
    CALLS: getCaretRect (text-editor)
    Uses the current caret's Y position minus one line height to hit-test the Paragraph and move the cursor up one line.

  ---

  FUNCTION moveDown(extend?) -> void [2026-03-26]
    CALLS: getCaretRect (text-editor)
    Uses the current caret's Y position plus one line height to move the cursor down one line.

  ---

  FUNCTION moveToLineStart(extend?) -> void [2026-03-26]
    Moves cursor to the startIndex of the line that contains the current cursor position.

  ---

  FUNCTION moveToLineEnd(extend?) -> void [2026-03-26]
    Moves cursor to endExcludingWhitespaces of the current line.

  ---

  FUNCTION moveWordLeft(extend?) -> void [2026-03-26]
    Skips over whitespace/punctuation then word characters to the left, landing at the previous word boundary.

  ---

  FUNCTION moveWordRight(extend?) -> void [2026-03-26]
    Skips over word characters then whitespace/punctuation to the right, landing after the next word.

  ---

  FUNCTION getCaretRect() -> TextCaret | null [2026-03-26]
    Queries the Paragraph for glyph rects at the cursor position to determine the caret's X coordinate and vertical extent. Handles edge cases for empty text and start/end positions.

  ---

  FUNCTION getSelectionRects() -> Rect[] [2026-03-26]
    CALLS: getSelectionRange (text-editor)
    Queries the Paragraph for all highlight rectangles covering the selection range and returns them as Rect objects.
