// Mermaid Config
// Centralized Mermaid initialization for the app.
// Handles theme application and distinguishes between Mermaid diagrams and JSON-based design files.

FUNCTION hasCustomInit(content) -> boolean                              EXPORT
  Return true if the content contains a %%{init:...}%% directive.

---

FUNCTION initializeMermaid(theme, diagramContent?) -> Promise<void>     EXPORT
  CALLS: hasCustomInit (mermaidConfig)
  Build a Mermaid config with startOnLoad=false and securityLevel='loose'.
  IF the diagram does not have its own %%{init}%% directive, set the global theme
  ('dark' for dark mode, 'default' otherwise).
  IF the diagram has a custom init, omit the global theme so the diagram's directive takes full control.
  Call mermaid.initialize with the config.

---

FUNCTION isDesignDiagram(content) -> boolean                            EXPORT
  Return true if the content uses the legacy wireframe syntax (starts with 'wireframe').
  ELSE try parsing as JSON: return true if it has viewport and screens fields.
  Return false otherwise.
