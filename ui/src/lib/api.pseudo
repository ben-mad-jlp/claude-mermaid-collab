// API Client
// HTTP fetch wrapper for all backend REST endpoints.
// Covers sessions, diagrams, documents, designs, spreadsheets, snippets, terminal sessions, and todos.

FUNCTION generateSessionName() -> string                                EXPORT
  Pick two random adjectives and one random noun from built-in word lists.
  Return them joined as "adj1-adj2-noun".

---

FUNCTION api.getSessions() -> Session[]                                 EXPORT
  GET /api/sessions. Map response's 'session' field to frontend 'name' field.

---

FUNCTION api.createSession(project, session, sessionType, useRenderUI) -> Session   EXPORT
  POST /api/sessions. Return the created session using the server-expanded project path.

---

FUNCTION api.deleteSession(project, session) -> boolean                 EXPORT
  DELETE /api/sessions. Return response.success.

---

FUNCTION api.archiveSession(project, session, options) -> ArchiveResult EXPORT
  POST /api/sessions/archive. Defaults: deleteSession=true, timestamp=false.

---

FUNCTION api.getDiagrams(project, session) -> Diagram[]                 EXPORT
  GET /api/diagrams. Returns data.diagrams array.

---

FUNCTION api.getDocuments(project, session) -> Document[]               EXPORT
  GET /api/documents. Returns data.documents array.

---

FUNCTION api.getDiagram(project, session, id) -> Diagram | null         EXPORT
  GET /api/diagram/:id. Returns null on 404.

---

FUNCTION api.getDocument(project, session, id) -> Document | null       EXPORT
  GET /api/document/:id. Returns null on 404.

---

FUNCTION api.updateDiagram(project, session, id, content)               EXPORT
  PUT /api/diagrams/:id with JSON body { content }.

---

FUNCTION api.updateDocument(project, session, id, content)              EXPORT
  PUT /api/documents/:id with JSON body { content }.

---

FUNCTION api.killTerminalSession(sessionName)                           EXPORT
  POST /api/terminal/kill-session.

---

FUNCTION api.cleanupTerminalSessions(activeSessions) -> { killed, kept } EXPORT
  POST /api/terminal/cleanup.

---

FUNCTION api.getTerminalSessions(project, session) -> TerminalSession[] EXPORT
  GET /api/terminal/sessions.

---

FUNCTION api.createTerminalSession(project, session, name) -> CreateSessionResult EXPORT
  POST /api/terminal/sessions.

---

FUNCTION api.deleteTerminalSession(project, session, id)                EXPORT
  DELETE /api/terminal/sessions/:id.

---

FUNCTION api.renameTerminalSession(project, session, id, name)          EXPORT
  POST /api/terminal/sessions/:id/rename.

---

FUNCTION api.reorderTerminalSessions(project, session, orderedIds)      EXPORT
  PUT /api/terminal/sessions/reorder.

---

FUNCTION api.getSessionState(project, session) -> CollabState | null    EXPORT
  GET /api/session-state. Returns null on 404.

---

FUNCTION api.getUIState(project, session) -> CachedUIState | null       EXPORT
  GET /api/ui-state. Returns null when response has status='none'.

---

FUNCTION api.getDesigns / getDesign / updateDesign / getDesignHistory / getDesignVersion / deleteDesign  EXPORT
  Standard CRUD against /api/designs and /api/design/:id endpoints.

---

FUNCTION api.getSpreadsheets / getSpreadsheet / updateSpreadsheet / deleteSpreadsheet  EXPORT
  Standard CRUD against /api/spreadsheets and /api/spreadsheet/:id endpoints.

---

FUNCTION api.createSnippet / getSnippets / getSnippet / updateSnippet / deleteSnippet / applySnippet  EXPORT
  CRUD against /api/snippets and /api/snippet/:id endpoints.
  applySnippet posts to /api/snippet/:id/apply and returns { success, filePath, linesWritten }.

---

FUNCTION api.getTodos / addTodo / updateTodo / removeTodo               EXPORT
  CRUD against /api/todos and /api/todos/:id endpoints.
