// Remark Diagram Embeds Plugin
// A remark plugin that converts {{diagram:id}} and {{design:id}} embed syntax in markdown
// into image nodes so they can be resolved and rendered inline.

FUNCTION remarkDiagramEmbeds() -> Plugin                                EXPORT
  Recursively walk the AST.
  For each text node containing {{diagram:id}} or {{design:id}} patterns:
    Split the text on those patterns.
    Convert each matched embed to an image node with url = @diagram/<id> or @design/<id>.
    Leave non-embed text segments as text nodes.
  Replace the original children array with the expanded result.
