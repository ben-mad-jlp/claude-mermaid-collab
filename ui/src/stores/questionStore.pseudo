// Question Store
// Zustand store for managing Claude questions that require user input.
// Tracks the current active question, submission state, and question history.

State shape:
  currentQuestion: Question | null
  questionHistory: Question[]  (newest first)
  submitState: { loading, error, success }

FUNCTION submitQuestionResponse(response) -> Promise<void>
  CALLS: getWebSocketClient (websocket)
  Send a 'submit_question_response' message via the shared WebSocket client.
  Includes questionId, answer, and timestamp. Fire-and-forget: does not await a reply.

---

FUNCTION receiveQuestion(question)                                       EXPORT
  Set currentQuestion to the incoming question.
  Prepend it to questionHistory.

---

FUNCTION submitResponse(response) -> Promise<void>                      EXPORT
  CALLS: submitQuestionResponse (questionStore)
  IF no currentQuestion or its ID doesn't match the response's questionId, set error state and return.
  Set loading = true.
  Call submitQuestionResponse.
  On success: set success = true and clear currentQuestion.
  On failure: set error message.

---

FUNCTION dismissQuestion()                                               EXPORT
  Clear currentQuestion.
  Reset submitState to idle (loading=false, error=null, success=false).

---

FUNCTION getQuestionHistory() -> Question[]                              EXPORT
  Return questionHistory array.

---

FUNCTION clearHistory()                                                  EXPORT
  Set questionHistory to empty array.

---

FUNCTION setSubmitLoading(loading)                                       EXPORT
  Update submitState.loading.

---

FUNCTION setSubmitError(error)                                           EXPORT
  Update submitState.error.

---

FUNCTION setSubmitSuccess(success)                                       EXPORT
  Update submitState.success.

---

FUNCTION reset()                                                         EXPORT
  Reset all state to initial values: no current question, empty history, idle submit state.
