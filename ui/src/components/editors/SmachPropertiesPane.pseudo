// SmachPropertiesPane
// Side panel for editing SMACH YAML state machine properties.
// Shows the selected state's description and transitions, with inline editing
// for the description and add/remove controls for transitions.

FUNCTION isSmachContent(content) -> boolean                            EXPORT
  Returns true if the YAML content starts with a "states:" top-level key.

---

FUNCTION parseSmachState(content, stateName) -> SmachStateData         EXPORT
  Parses the YAML with js-yaml.
  Extracts the named state node and returns its transitions array.

---

FUNCTION SmachPropertiesPane(content, selectedState, onEditDescription, onEditTransition, onAddTransition, onRemoveTransition) -> JSX  EXPORT
  Calls parseSmachState to get the current state's data.
  Shows state name as header.
  Description section: inline textarea toggle (edit/save mode).
  Transitions section: list of transitions with remove (×) buttons, plus an
  "Add Transition" button.

---

FUNCTION handleSaveDescription() -> void
  Calls onEditDescription(selectedState, editedDescription).
  Exits editing mode.
