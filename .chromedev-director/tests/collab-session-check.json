{
  "id": "collab-session-check",
  "name": "collab-session-check",
  "definition": {
    "url": "http://localhost:3002/collab/session?session=test-session&project=/srv/codebase/open-collab",
    "steps": [
      {
        "wait": 3000
      },
      {
        "screenshot": true
      },
      {
        "eval": "document.body.innerHTML.slice(0, 2000)",
        "as": "bodyHtml"
      },
      {
        "eval": "document.querySelector('[data-testid=\"split-editor-host\"]') ? 'found' : 'missing'",
        "as": "splitEditorHost"
      },
      {
        "eval": "document.querySelector('[data-testid=\"tab-bar\"]') ? 'found' : 'missing'",
        "as": "tabBar"
      },
      {
        "eval": "document.querySelector('[data-testid=\"pane-content\"]') ? 'found' : 'missing'",
        "as": "paneContent"
      },
      {
        "eval": "document.querySelector('[data-testid=\"sidebar\"]') ? 'found' : 'missing'",
        "as": "sidebar"
      }
    ]
  },
