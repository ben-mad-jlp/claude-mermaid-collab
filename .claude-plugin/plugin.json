{
  "name": "mermaid-collab",
  "description": "Collaborative design workflows for Claude Code: mermaid diagrams, wireframes, and design-to-implementation pipelines with real-time preview",
  "version": "5.59.0",
  "author": {
    "name": "Ben Maderazo"
  },
  "homepage": "https://github.com/ben-mad-jlp/claude-mermaid-collab",
  "repository": "https://github.com/ben-mad-jlp/claude-mermaid-collab",
  "license": "MIT",
  "keywords": [
    "collaboration",
    "mermaid",
    "wireframes",
    "design",
    "diagrams",
    "workflows",
    "mcp"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-start-hook.sh"
          },
          {
            "type": "command",
            "command": "mkdir -p \"${HOME}/.claude-mermaid-collab\" && touch \"${HOME}/.claude-mermaid-collab/pseudo-rescan-${PWD//\\//_}.marker\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/active-hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/active-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/active-hook.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/permission-hook.sh"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/permission-denied-hook.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notification-hook.sh"
          }
        ]
      }
    ]
  }
}
