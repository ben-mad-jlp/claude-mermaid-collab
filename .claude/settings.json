{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(cd * && git *)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/prune-merged-worktrees.sh\"",
            "timeout": 30,
            "statusMessage": "Pruning merged worktrees…"
          }
        ]
      }
    ]
  }
}
